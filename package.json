{
  "name": "leva-vanilla",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier . --write",
    "lint": "eslint . --fix"
  },
  "main": "dist/leva-vanilla.cjs",
  "module": "dist/leva-vanilla.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/leva-vanilla.js",
      "require": "./dist/leva-vanilla.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/three": "^0.182.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "three": "0.182.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.2.4",
    "vite-plugin-lib-inject-css": "^2.2.2"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint . --fix",
      "prettier . --write",
      "git add"
    ],
    "*.{json,md}": [
      "prettier . --write",
      "git add"
    ]
  }
}
