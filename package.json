{
  "name": "leva-vanilla",
  "version": "0.0.5",
  "description": "A lightweight, framework-agnostic control panel inspired by Leva — built for plain JavaScript.",
  "type": "module",
  "author": "Alkebsi",
  "license": "MIT",
  "keywords": [
    "gui",
    "datgui",
    "leva",
    "lil-gui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alkebsi/leva-vanilla.git"
  },
  "bugs": {
    "url": "https://github.com/Alkebsi/leva-vanilla/issues"
  },
  "homepage": "https://github.com/Alkebsi/leva-vanilla#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "docs": "tsc && vite build --config vite.config.demo.ts",
    "prepare": "husky",
    "format": "prettier . --write",
    "lint": "eslint . --fix"
  },
  "main": "dist/leva-vanilla.cjs",
  "module": "dist/leva-vanilla.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/leva-vanilla.js",
      "require": "./dist/leva-vanilla.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.2.4",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint . --fix",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier . --write"
    ]
  }
}
